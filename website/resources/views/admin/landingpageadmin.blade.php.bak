<!DOCTYPE html>
<html lang="{{ str_replace('_', '-', app()->getLocale()) }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Prestige Legal AI</title>
    
    <!-- Scripts / Styles -->
    @vite(['resources/css/app.css', 'resources/js/app.js'])
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <style>
        @keyframes float-slow {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-15px); }
            100% { transform: translateY(0px); }
        }
        .animate-float {
            animation: float-slow 6s ease-in-out infinite;
        }
        .animate-float-delayed {
            animation: float-slow 8s ease-in-out infinite;
            animation-delay: 2s;
        }
        .muted-cinema {
            filter: saturate(0.7) contrast(0.95) brightness(0.95);
        }
        @media (min-width: 1024px) {
            .hero-grid {
                flex-direction: row !important;
            }
            .hero-left {
                width: 50% !important;
            }
            .hero-right {
                width: 50% !important;
                min-height: 100vh !important;
            }
            .hero-gradient {
                display: block !important;
                position: absolute;
                inset: 0;
                z-index: 10;
                background: linear-gradient(to right, #f9f9fe 0%, #f9f9fe 0%, rgba(249, 249, 254, 0) 100%) !important;
            }
        }
        .hero-gradient {
            display: none;
        }
        #loading-screen {
            position: fixed;
            top: -5vh;
            left: -5vw;
            width: 110vw;
            height: 110vh;
            z-index: 10000;
            overflow: hidden;
            background-color: #1D5083 !important; /* Solid background at start */
        }
        .panel {
            position: absolute;
            inset: 0;
            background-color: #1D5083;
        }
        .panel-left {
            right: 50%;
        }
        .panel-right {
            left: 50%;
        }
    </style>
    <!-- GSAP -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
</head>
<body class="landingpage1 min-h-screen relative overflow-x-hidden " style="background-color: rgba(249, 249, 254, 0.1);">
    <!-- Cinematic Loading Screen -->
    <div id="loading-screen">
        <!-- SVG Panels and Crack -->
        <svg class="absolute inset-0 w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
            <!-- Left Panel -->
            <g id="panel-left-group">
                <path d="M -1 0 L 50 0 L 49 15 L 52 30 L 47 50 L 53 70 L 48 85 L 50 100 L -1 100 Z" fill="#1D5083" stroke="#1D5083" stroke-width="1" />
            </g>
            
            <!-- Right Panel -->
            <g id="panel-right-group">
                <path d="M 101 0 L 50 0 L 49 15 L 52 30 L 47 50 L 53 70 L 48 85 L 50 100 L 101 100 Z" fill="#1D5083" stroke="#1D5083" stroke-width="1" />
            </g>
            
            <!-- Crack Path (On top, made thick as requested) -->
            <path id="crack-path" d="M 50 0 L 49 15 L 52 30 L 47 50 L 53 70 L 48 85 L 50 100" stroke="rgba(255, 255, 255, 0.9)" stroke-width="3" fill="none" style="opacity: 0;" />
        </svg>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // Set initial dasharray and dashoffset for the crack
            const crackPath = document.getElementById("crack-path");
            if (crackPath) {
                crackPath.style.strokeDasharray = "300";
                crackPath.style.strokeDashoffset = "300";
            }

            const tl = gsap.timeline();

            // Stage 1 & 2: Silent Pause (Solid blue)
            tl.to({}, {duration: 1.0})

            // Rev 2: Efek gempa bumi kecil
            .to("#loading-screen", {
                x: "+=3",
                yoyo: true,
                repeat: 4,
                duration: 0.05,
                ease: "power1.inOut"
            })

            // Rev 2: Terjadi retakan kecil (smooth, tidak tiba-tiba)
            .fromTo("#crack-path", {
                strokeDashoffset: "300",
                strokeWidth: 0.5,
                opacity: 0
            }, {
                strokeDashoffset: "0",
                opacity: 1,
                duration: 0.8,
                ease: "power2.out"
            })
            
            // Rev 3: Efek gempa bumi yang lebih kuat
            .to("#loading-screen", {
                x: "+=10",
                yoyo: true,
                repeat: 8,
                duration: 0.04,
                ease: "power1.inOut"
            })
            
            // Rev 3: Terjadi retakan besar (widening) selama gempa kuat
            .to("#crack-path", {
                strokeWidth: 5,
                duration: 0.4,
                ease: "expo.out"
            }, "<")

            // Stage 4: Screen Splitting (IMMEDIATELY after crack, duration 2s, using super smooth expo easing)
            .to("#panel-left-group", {
                xPercent: -100,
                duration: 2.0,
                ease: "expo.inOut"
            })
            .to("#panel-right-group", {
                xPercent: 100,
                duration: 2.0,
                ease: "expo.inOut"
            }, "<")
            
            // Fade out the loading screen background to reveal the page
            .to("#loading-screen", {
                backgroundColor: "rgba(29, 80, 131, 0)",
                duration: 0.5,
                ease: "power2.out"
            }, "<")

            // Softly fade in the page content behind the splitting panels
            .to("#app-content", {
                opacity: 1,
                duration: 1.5,
                ease: "power2.out"
            }, "<")

            // Remove the loading screen from view
            .to("#loading-screen", {
                display: "none",
                duration: 0.1
            });
        });
    </script>
    <div id="app-content" style="opacity: 0;">
    <!-- Header / Nav -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-xl border-b border-gray-100 h-20 flex items-center px-10">
        <div class="max-w-[1440px] w-full mx-auto flex justify-between items-center">
            <!-- Logo -->
            <div class="flex items-center gap-2 cursor-pointer group">
                <!-- Lucide Scale Icon -->
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#003966] w-8 h-8 group-hover:scale-105 transition-transform"><path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="M7 21h10"/><path d="M12 3v18"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/></svg>
                <span class="font-serif text-2xl text-[#003966] italic tracking-tight">Lawsy</span>
